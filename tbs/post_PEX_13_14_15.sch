C {code_shown.sym} 1520 -975 0 0 {name=s1 only_toplevel=false value="
.control
let vlow = 0
let vhigh = 3.3
* A = 1010101010101010 = 43690
alter VA15 = $&vhigh
alter VA14 = $&vlow
alter VA13 = $&vhigh
alter VA12 = $&vlow
alter VA11 = $&vhigh
alter VA10 = $&vlow
alter VA9  = $&vhigh
alter VA8  = $&vlow
alter VA7  = $&vhigh
alter VA6  = $&vlow
alter VA5  = $&vhigh
alter VA4  = $&vlow
alter VA3  = $&vhigh
alter VA2  = $&vlow
alter VA1  = $&vhigh
alter VA0  = $&vlow


* --- SHIFT 1 (0001) ---
alter vSh1 = $&vhigh
alter vSh2 = $&vlow
alter vSh4 = $&vlow
alter vSh8 = $&vlow

alter vSh1b = $&vlow
alter vSh2b = $&vhigh
alter vSh4b = $&vhigh
alter vSh8b = $&vhigh
tran 10n 1u

meas tran v14_0  find v(OUT0)  at=30n
meas tran v14_1  find v(OUT1)  at=30n
meas tran v14_2  find v(OUT2)  at=30n
meas tran v14_3  find v(OUT3)  at=30n
meas tran v14_4  find v(OUT4)  at=30n
meas tran v14_5  find v(OUT5)  at=30n
meas tran v14_6  find v(OUT6)  at=30n
meas tran v14_7  find v(OUT7)  at=30n
meas tran v14_8  find v(OUT8)  at=30n
meas tran v14_9  find v(OUT9)  at=30n
meas tran v14_10 find v(OUT10) at=30n
meas tran v14_11 find v(OUT11) at=30n
meas tran v14_12 find v(OUT12) at=30n
meas tran v14_13 find v(OUT13) at=30n
meas tran v14_14 find v(OUT14) at=30n
meas tran v14_15 find v(OUT15) at=30n

let res14 = 0
if v14_0 > 1.6
  let res14 = res14 + 1
end
if v14_1 > 1.6
  let res14 = res14 + 2
end
if v14_2 > 1.6
  let res14 = res14 + 4
end
if v14_3 > 1.6
  let res14 = res14 + 8
end
if v14_4 > 1.6
  let res14 = res14 + 16
end
if v14_5 > 1.6
  let res14 = res14 + 32
end
if v14_6 > 1.6
  let res14 = res14 + 64
end
if v14_7 > 1.6
  let res14 = res14 + 128
end
if v14_8 > 1.6
  let res14 = res14 + 256
end
if v14_9 > 1.6
  let res14 = res14 + 512
end
if v14_10 > 1.6
  let res14 = res14 + 1024
end
if v14_11 > 1.6
  let res14 = res14 + 2048
end
if v14_12 > 1.6
  let res14 = res14 + 4096
end
if v14_13 > 1.6
  let res14 = res14 + 8192
end
if v14_14 > 1.6
  let res14 = res14 + 16384
end
if v14_15 > 1.6
  let res14 = res14 + 32768
end
echo "14_gives_32768"
print res14

.endc
"}
