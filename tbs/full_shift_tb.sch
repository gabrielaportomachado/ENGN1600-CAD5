C {code_shown.sym} 500 -855 0 0 {name=s1 only_toplevel=false value="
.control
let vlow = 0
let vhigh = 3.3

* A = 1010101010101010 = 43690
alter VA15 = $&vhigh
alter VA14 = $&vlow
alter VA13 = $&vhigh
alter VA12 = $&vlow
alter VA11 = $&vhigh
alter VA10 = $&vlow
alter VA9  = $&vhigh
alter VA8  = $&vlow
alter VA7  = $&vhigh
alter VA6  = $&vlow
alter VA5  = $&vhigh
alter VA4  = $&vlow
alter VA3  = $&vhigh
alter VA2  = $&vlow
alter VA1  = $&vhigh
alter VA0  = $&vlow

* --- Define Shift Control Values ---
alter vSh8 = $&vlow
alter vSh4 = $&vlow
alter vSh2 = $&vlow
alter vSh1 = $&vhigh
alter vSh8b = $&vhigh
alter vSh4b = $&vhigh
alter vSh2b = $&vhigh
alter vSh1b = $&vlow

* Run transient
tran 100n 100u

* --- Digitizing Input A (Measurement at 30ns) ---
meas tran a0  find v(A0)  at=30n
meas tran a1  find v(A1)  at=30n
meas tran a2  find v(A2)  at=30n
meas tran a3  find v(A3)  at=30n
meas tran a4  find v(A4)  at=30n
meas tran a5  find v(A5)  at=30n
meas tran a6  find v(A6)  at=30n
meas tran a7  find v(A7)  at=30n
meas tran a8  find v(A8)  at=30n
meas tran a9  find v(A9)  at=30n
meas tran a10 find v(A10) at=30n
meas tran a11 find v(A11) at=30n
meas tran a12 find v(A12) at=30n
meas tran a13 find v(A13) at=30n
meas tran a14 find v(A14) at=30n
meas tran a15 find v(A15) at=30n

* --- Digitizing Output (Measurement at 30ns) ---
meas tran v0  find v(OUT0)  at=30n
meas tran v1  find v(OUT1)  at=30n
meas tran v2  find v(OUT2)  at=30n
meas tran v3  find v(OUT3)  at=30n
meas tran v4  find v(OUT4)  at=30n
meas tran v5  find v(OUT5)  at=30n
meas tran v6  find v(OUT6)  at=30n
meas tran v7  find v(OUT7)  at=30n
meas tran v8  find v(OUT8)  at=30n
meas tran v9  find v(OUT9)  at=30n
meas tran v10 find v(OUT10) at=30n
meas tran v11 find v(OUT11) at=30n
meas tran v12 find v(OUT12) at=30n
meas tran v13 find v(OUT13) at=30n
meas tran v14 find v(OUT14) at=30n
meas tran v15 find v(OUT15) at=30n

* Initialize tracking variables
let input_A_decimal = 0
let decimal_result = 0

* Logic checks for Input A and Output
if a0 > 1.6 | let input_A_decimal = input_A_decimal + 1 | end
if v0 > 1.6 | let decimal_result = decimal_result + 1 | end

if a1 > 1.6 | let input_A_decimal = input_A_decimal + 2 | end
if v1 > 1.6 | let decimal_result = decimal_result + 2 | end

if a2 > 1.6 | let input_A_decimal = input_A_decimal + 4 | end
if v2 > 1.6 | let decimal_result = decimal_result + 4 | end

if a3 > 1.6 | let input_A_decimal = input_A_decimal + 8 | end
if v3 > 1.6 | let decimal_result = decimal_result + 8 | end

if a4 > 1.6 | let input_A_decimal = input_A_decimal + 16 | end
if v4 > 1.6 | let decimal_result = decimal_result + 16 | end

if a5 > 1.6 | let input_A_decimal = input_A_decimal + 32 | end
if v5 > 1.6 | let decimal_result = decimal_result + 32 | end

if a6 > 1.6 | let input_A_decimal = input_A_decimal + 64 | end
if v6 > 1.6 | let decimal_result = decimal_result + 64 | end

if a7 > 1.6 | let input_A_decimal = input_A_decimal + 128 | end
if v7 > 1.6 | let decimal_result = decimal_result + 128 | end

if a8 > 1.6 | let input_A_decimal = input_A_decimal + 256 | end
if v8 > 1.6 | let decimal_result = decimal_result + 256 | end

if a9 > 1.6 | let input_A_decimal = input_A_decimal + 512 | end
if v9 > 1.6 | let decimal_result = decimal_result + 512 | end

if a10 > 1.6 | let input_A_decimal = input_A_decimal + 1024 | end
if v10 > 1.6 | let decimal_result = decimal_result + 1024 | end

if a11 > 1.6 | let input_A_decimal = input_A_decimal + 2048 | end
if v11 > 1.6 | let decimal_result = decimal_result + 2048 | end

if a12 > 1.6 | let input_A_decimal = input_A_decimal + 4096 | end
if v12 > 1.6 | let decimal_result = decimal_result + 4096 | end

if a13 > 1.6 | let input_A_decimal = input_A_decimal + 8192 | end
if v13 > 1.6 | let decimal_result = decimal_result + 8192 | end

if a14 > 1.6 | let input_A_decimal = input_A_decimal + 16384 | end
if v14 > 1.6 | let decimal_result = decimal_result + 16384 | end

if a15 > 1.6 | let input_A_decimal = input_A_decimal + 32768 | end
if v15 > 1.6 | let decimal_result = decimal_result + 32768 | end

* --- Output Results ---
print input_A_decimal
print decimal_result
.endc
"}
